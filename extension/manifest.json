{
  "manifest_version": 3,
  "name": "Mentora",
  "version": "1.0.0",
  "description": "Real-time multimodal academic tutor powered by Gemini Live API.",

  "permissions": [
    "sidePanel",
    "offscreen",
    "tabCapture",
    "scripting",
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "https://mentora-backend-703396951656.us-central1.run.app/*"
  ],

  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },

  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Mentora",
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "icons": {
    "16":  "assets/icons/icon16.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'self'; img-src 'self' data:; connect-src ws://localhost:8080 wss://mentora-backend-703396951656.us-central1.run.app"
  }

}
